# ----------------------------------------------------------------------------
# AI Meeting Notes Generator — Environment Variables
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values.  `.env` is gitignored.
# Every variable here is validated at startup by `src/lib/env.ts` (Zod), so a
# missing or malformed value fails fast with a clear error instead of a vague
# runtime crash deep inside a request.
# ----------------------------------------------------------------------------

# --- Database (PostgreSQL) ---------------------------------------------------
# A standard Postgres connection string. For local dev use a local Postgres or
# a free hosted DB (Neon / Supabase). On Vercel, set this in Project Settings.
# Example (Neon): postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/db?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# --- Transcription service (faster-whisper, Python sidecar) ------------------
# URL of the local FastAPI service in `transcription-service/` that wraps
# faster-whisper. Start it with: cd transcription-service && uvicorn main:app --port 8000
TRANSCRIPTION_SERVICE_URL="http://localhost:8000"

# --- Ollama (local Llama 3 for summary + action-item extraction) -------------
# Install Ollama (https://ollama.com), then: `ollama pull llama3`
# Ollama serves an HTTP API on port 11434 by default.
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3"

# --- Cloudinary (audio file storage) ----------------------------------------
# Find these on your Cloudinary dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
# Folder inside Cloudinary where meeting audio is stored.
CLOUDINARY_UPLOAD_FOLDER="meeting-notes"
